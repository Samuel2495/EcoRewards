{
    "name": "ecorewards-monorepo",
    "private": true,
    "workspaces": [
        "frontend",
        "backend"
    ],
    "scripts": {
        "build": "npm run build --workspace=frontend",
        "frontend:dev": "npm run dev --workspace=frontend",
        "backend:dev": "npm run dev --workspace=backend",
        "dev": "concurrently \"npm run frontend:dev\" \"npm run backend:dev\"",
        "install:all": "npm install && npm install --workspace=frontend && npm install --workspace=backend"
    },
    "devDependencies": {
        "concurrently": "^8.2.2"
    }
}